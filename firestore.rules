rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSpaceMember(spaceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/spaces/$(spaceId))
        && get(/databases/$(database)/documents/spaces/$(spaceId)).data.memberUids.hasAny([request.auth.uid]);
    }

    function isSpaceOwner(spaceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/spaces/$(spaceId))
        && get(/databases/$(database)/documents/spaces/$(spaceId)).data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow create, read, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /spaces/{spaceId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.projectName is string
        && request.resource.data.projectName.size() > 0
        && request.resource.data.projectKey is string
        && request.resource.data.projectKey.size() == 6
        && request.resource.data.memberUids is list
        && request.resource.data.memberUids.size() == 1
        && request.resource.data.memberUids.hasAny([request.auth.uid]);

      allow read: if isSpaceMember(spaceId);
      allow update, delete: if isSpaceOwner(spaceId);

      match /tasks/{taskId} {
        allow read, create, update, delete: if isSpaceMember(spaceId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
