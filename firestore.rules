rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userSpaceDoc(userId, spaceId) {
      return /databases/$(database)/documents/users/$(userId)/spaces/$(spaceId);
    }

    function legacySpaceDoc(spaceId) {
      return /databases/$(database)/documents/spaces/$(spaceId);
    }

    function projectDoc(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }

    function isUserSpaceMember(userId, spaceId) {
      return signedIn()
        && exists(userSpaceDoc(userId, spaceId))
        && get(userSpaceDoc(userId, spaceId)).data.memberUids.hasAny([request.auth.uid]);
    }

    function isUserSpaceOwner(userId, spaceId) {
      return signedIn()
        && exists(userSpaceDoc(userId, spaceId))
        && get(userSpaceDoc(userId, spaceId)).data.ownerUid == request.auth.uid;
    }

    function isLegacySpaceMember(spaceId) {
      return signedIn()
        && exists(legacySpaceDoc(spaceId))
        && get(legacySpaceDoc(spaceId)).data.memberUids.hasAny([request.auth.uid]);
    }

    function isLegacySpaceOwner(spaceId) {
      return signedIn()
        && exists(legacySpaceDoc(spaceId))
        && get(legacySpaceDoc(spaceId)).data.ownerUid == request.auth.uid;
    }

    function isProjectOwner(projectId) {
      return signedIn()
        && exists(projectDoc(projectId))
        && get(projectDoc(projectId)).data.ownerId == request.auth.uid;
    }

    function isProjectMember(projectId) {
      return signedIn()
        && exists(projectDoc(projectId))
        && get(projectDoc(projectId)).data.members.hasAny([request.auth.uid]);
    }

    function canAccessProject(projectId) {
      return isProjectOwner(projectId) || isProjectMember(projectId);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == userId;

      match /spaces/{spaceId} {
        allow create: if signedIn()
          && userId == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.projectName is string
          && request.resource.data.projectName.size() > 0
          && request.resource.data.projectKey is string
          && request.resource.data.projectKey.size() == 6
          && request.resource.data.memberUids is list
          && request.resource.data.memberUids.size() == 1
          && request.resource.data.memberUids.hasAny([request.auth.uid]);

        allow read: if request.auth.uid == userId || isUserSpaceMember(userId, spaceId);
        allow update, delete: if isUserSpaceOwner(userId, spaceId);

        match /tasks/{taskId} {
          allow read: if request.auth.uid == userId || isUserSpaceMember(userId, spaceId);

          allow create: if signedIn()
            && (request.auth.uid == userId || isUserSpaceMember(userId, spaceId))
            && request.resource.data.spaceId == spaceId
            && request.resource.data.description is string
            && request.resource.data.taskName is string
            && request.resource.data.taskName.size() > 0
            && request.resource.data.issueTag is string
            && (request.resource.data.issueTag == "task"
              || request.resource.data.issueTag == "story"
              || request.resource.data.issueTag == "epic")
            && request.resource.data.priority is string
            && (request.resource.data.priority == "low"
              || request.resource.data.priority == "medium"
              || request.resource.data.priority == "high")
            && request.resource.data.status is string
            && (request.resource.data.status == "todo"
              || request.resource.data.status == "in-progress"
              || request.resource.data.status == "review"
              || request.resource.data.status == "done")
            && request.resource.data.createdByUid == request.auth.uid;

          allow update: if signedIn()
            && (request.auth.uid == userId || isUserSpaceMember(userId, spaceId))
            && request.resource.data.spaceId == spaceId;

          allow delete: if request.auth.uid == userId || isUserSpaceMember(userId, spaceId);
        }
      }
    }

    match /projects/{projectId} {
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.ownerId
        && request.resource.data.projectId == projectId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.members is list
        && request.resource.data.members.size() == 1
        && request.resource.data.members.hasAny([request.auth.uid]);

      allow read: if canAccessProject(projectId);

      allow update: if signedIn()
        && canAccessProject(projectId)
        && request.resource.data.projectId == projectId
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isProjectOwner(projectId);

      match /tasks/{taskId} {
        allow read: if canAccessProject(projectId)
          && (resource.data.visibility != "owner" || isProjectOwner(projectId));

        allow create: if signedIn()
          && canAccessProject(projectId)
          && request.resource.data.projectId == projectId
          && request.resource.data.taskId == taskId
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.description is string
          && request.resource.data.status is string
          && (request.resource.data.status == "todo"
            || request.resource.data.status == "progress"
            || request.resource.data.status == "done")
          && (request.resource.data.assignedTo == null || request.resource.data.assignedTo is string)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.visibility is string
          && (
            (request.resource.data.visibility == "project" && canAccessProject(projectId))
            || (request.resource.data.visibility == "owner" && isProjectOwner(projectId))
          );

        allow update: if signedIn()
          && canAccessProject(projectId)
          && request.resource.data.projectId == projectId
          && request.resource.data.taskId == taskId
          && request.resource.data.createdBy == resource.data.createdBy
          && (resource.data.visibility != "owner" || isProjectOwner(projectId));

        allow delete: if canAccessProject(projectId)
          && (resource.data.visibility != "owner" || isProjectOwner(projectId));
      }
    }

    match /spaces/{spaceId} {
      allow read: if isLegacySpaceOwner(spaceId) || isLegacySpaceMember(spaceId);
      allow update, delete: if isLegacySpaceOwner(spaceId);

      match /tasks/{taskId} {
        allow read: if isLegacySpaceOwner(spaceId) || isLegacySpaceMember(spaceId);
        allow create: if signedIn()
          && (isLegacySpaceOwner(spaceId) || isLegacySpaceMember(spaceId))
          && request.resource.data.spaceId == spaceId
          && request.resource.data.description is string
          && request.resource.data.taskName is string
          && request.resource.data.taskName.size() > 0
          && request.resource.data.issueTag is string
          && (request.resource.data.issueTag == "task"
            || request.resource.data.issueTag == "story"
            || request.resource.data.issueTag == "epic")
          && request.resource.data.priority is string
          && (request.resource.data.priority == "low"
            || request.resource.data.priority == "medium"
            || request.resource.data.priority == "high")
          && request.resource.data.status is string
          && (request.resource.data.status == "todo"
            || request.resource.data.status == "in-progress"
            || request.resource.data.status == "review"
            || request.resource.data.status == "done")
          && request.resource.data.createdByUid == request.auth.uid;
        allow update: if signedIn()
          && (isLegacySpaceOwner(spaceId) || isLegacySpaceMember(spaceId))
          && request.resource.data.spaceId == spaceId;

        allow delete: if isLegacySpaceOwner(spaceId) || isLegacySpaceMember(spaceId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
