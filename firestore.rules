current 


rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update, delete: if signedIn() && request.auth.uid == userId;
    }

    // Starter rule for a future task collection.
    // Tighten this further when you add teams, boards, and role-based access.
    match /tasks/{taskId} {
      allow read, create, update, delete: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
